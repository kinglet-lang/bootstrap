using io;

// --- Enums ---
enum Color {
  Red,
  Green,
  Blue,
}

// --- Structs ---
struct Point {
  int x;
  int y;
}

// --- Generics ---
struct Box<T> {
  T value;
}

struct Pair<A, B> {
  A first;
  B second;
}

T identity<T>(T x) => x;

// --- Functions ---
int distance_sq(Point a, Point b) {
  int dx = a.x - b.x;
  int dy = a.y - b.y;
  return dx * dx + dy * dy;
}

string color_name(int c) {
  return inspect c {
    0 => "Red",
    1 => "Green",
    2 => "Blue",
    _ => "Unknown",
  };
}

int factorial(int n) {
  if n <= 1 {
    return 1;
  }
  return n * factorial(n - 1);
}

int main() {
  // Variables and arithmetic
  int x = 10;
  string greeting = "Hello, Kinglet!";
  bool flag = true;

  io::out.line(greeting);
  io::out.line("{}", x + 5);

  // Structs and field access
  Point origin { 0, 0 };
  Point target { 3, 4 };
  io::out.line("{}", distance_sq(origin, target));

  // Mutation
  target.x = 6;
  target.y = 8;
  io::out.line("{}", distance_sq(origin, target));

  // Generics
  Box<int> bi { 42 };
  Box<string> bs { "boxed" };
  io::out.line("{}", bi.value);
  io::out.line("{}", bs.value);
  io::out.line("{}", identity<int>(99));
  io::out.line("{}", identity<string>("generic"));

  // Nested generics
  Box<Box<int>> nested { bi };
  io::out.line("{}", nested.value.value);

  // Control flow
  if flag {
    io::out.line("flag is true");
  } else {
    io::out.line("flag is false");
  }

  // Loops
  int sum = 0;
  for (int i = 0; i < 5; i = i + 1) {
    sum = sum + i;
  }
  io::out.line("{}", sum);

  int count = 3;
  while count > 0 {
    io::out.line("{}", count);
    count = count - 1;
  }

  // Recursion
  io::out.line("{}", factorial(6));

  // Inspect (pattern matching)
  int color = 1;
  io::out.line("{}", color_name(color));

  return 0;
}
