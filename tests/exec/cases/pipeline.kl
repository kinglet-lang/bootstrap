// RUN: run

using io;

int twice(int x) => x * 2;
int add_one(int x) => x + 1;
int negate(int x) => 0 - x;

int main() {
  int result = 5 |> twice |> add_one;
  io::out.line("5 |> twice |> add_one = {}", result);

  int r2 = 3 |> add_one |> twice |> negate;
  io::out.line("3 |> add_one |> twice |> negate = {}", r2);

  return 0;
}
