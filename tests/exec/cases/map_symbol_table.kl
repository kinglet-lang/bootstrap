// RUN: run

using io;

struct Symbol { string name; int kind; }

int main() {
  {string: Symbol} table = {};
  table["x"] = Symbol { "x", 1 };
  table["y"] = Symbol { "y", 2 };

  if (table.has("x")) {
    Symbol s = table["x"];
    io::out.line("found: {} kind={}", s.name, s.kind);
  }

  Symbol missing = table["z"];
  if (missing == null) {
    io::out.line("z not found");
  }

  io::out.line("total={}", table.len());

  string[] names = table.keys();
  int i = 0;
  while (i < names.len()) {
    Symbol s = table[names[i]];
    io::out.line("  {} -> kind={}", s.name, s.kind);
    i = i + 1;
  }
  return 0;
}
