using io;

struct Point {
  int x;
  int y;
}

impl Point {
  int sum(self) {
    return self.x + self.y;
  }

  Point translate(self, int dx, int dy) {
    return Point { self.x + dx, self.y + dy };
  }
}

int main() {
  Point p { 3, 4 };
  io::out("{}\n", p.sum());
  Point q = p.translate(10, 20);
  io::out("{} {}\n", q.x, q.y);
  return 0;
}
