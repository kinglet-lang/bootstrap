using io;

int main() {
  int[] arr = [1, 2, 3, 4, 5];

  io::out.line("len: {}", arr.len());

  arr.push(6);
  io::out.line("after push: len = {}", arr.len());

  int last = arr.pop();
  io::out.line("popped: {}", last);

  int removed = arr.remove(0);
  io::out.line("removed at 0: {}", removed);

  io::out.line("contains 3: {}", arr.contains(3));
  io::out.line("contains 99: {}", arr.contains(99));

  arr.clear();
  io::out.line("after clear: len = {}", arr.len());

  return 0;
}
