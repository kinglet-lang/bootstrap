using io;

int main() {
  {string: int} m = {};
  m["a"] = 1;
  m["b"] = 2;
  m["c"] = 3;
  io::out.line("len={}", m.len());
  io::out.line("a={}", m["a"]);

  int missing = m["z"];
  if (missing == null) {
    io::out.line("missing=null");
  }

  io::out.line("has_b={}", m.has("b"));
  m.remove("b");
  io::out.line("has_b_after={}", m.has("b"));
  io::out.line("len_after={}", m.len());

  string[] ks = m.keys();
  io::out.line("keys_len={}", ks.len());

  {string: int} m2 = {"x": 10, "y": 20};
  io::out.line("x={} y={}", m2["x"], m2["y"]);

  {int: string} idx = {};
  idx[0] = "zero";
  idx[1] = "one";
  io::out.line("idx0={} idx1={}", idx[0], idx[1]);
  io::out.line("has0={}", idx.has(0));

  return 0;
}
