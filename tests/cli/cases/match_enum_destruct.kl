using io;

enum Option {
  Some(int),
  None,
}

int main() {
  Option x = Option::Some(42);
  int result = x match {
    Option::Some(let v) => v,
    Option::None => 0,
  };
  io::out.line("{}", result);

  Option y = Option::None;
  int result2 = y match {
    Option::Some(let v) => v,
    Option::None => -1,
  };
  io::out.line("{}", result2);

  return 0;
}
